{
  "name": "timetable.icu",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "db:scrape": "python3 scripts/main.py",
    "db:seed:local": "find .wrangler -name '*.sqlite' -not -name '*shm' -not -name '*wal' -exec bun src/db/seed.ts {} +",
    "db:sync": "bun run db:scrape && bun run db:seed:local",
    "db:push:remote": "python3 scripts/to_sql.py && wrangler d1 execute timetable_icu --file=./sync_remote.sql --remote",
    "db:deploy": "bun run db:scrape && bun run db:push:remote"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.3",
    "@astrojs/react": "^5.0.1",
    "@better-auth/passkey": "^1.5.6",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.0.8",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "bun-types": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "wrangler": "^4.77.0"
  }
}