{
  "name": "timetable.icu",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "db:scrape": "python3 scripts/main.py",
    "db:seed:local": "find .wrangler/state/v3/d1 -name '*.sqlite' ! -name '*shm' ! -name '*wal' -exec bun src/db/seed.ts {} \\;",
    "db:sync": "bun run db:scrape && bun run db:seed:local",
    "db:push:remote": "python3 scripts/to_sql.py && wrangler d1 execute timetable_icu --file=./sync_remote.sql --remote",
    "db:deploy": "bun run db:scrape && bun run db:push:remote"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "13.1.6",
    "@astrojs/react": "5.0.2",
    "@better-auth/passkey": "^1.5.6",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "6.1.2",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "lucide-astro": "^0.556.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "bun-types": "^1.3.11",
    "daisyui": "^5.5.19",
    "drizzle-kit": "^0.31.10",
    "wrangler": "^4.79.0"
  }
}