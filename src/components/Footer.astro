---
import {Calendar, Telescope} from "lucide-astro";
import {useTranslations, useTranslatedPath} from "@/translation/utils";

const lang = Astro.locals.lang || 'en';
const t = useTranslations(lang);
const l = useTranslatedPath(lang);

const {pathname} = Astro.url;

const isActive = (path: string) => {
    const translatedPath = l(path);
    return pathname === translatedPath || pathname === `${translatedPath}/`;
};
---

<footer class="hidden md:flex dock bg-base-100/80 backdrop-blur-lg border-t border-white/10">
    <a href={l('/explore')}
       class={`transition-colors ${isActive('/explore') ? 'dock-active text-primary' : 'text-base-content'}`}>
        <Telescope size="24"/>
        <span class="dock-label">{t('nav.explore')}</span>
    </a>
    <a href={l('/timetable')}
       class={`transition-colors ${isActive('/timetable') ? 'dock-active text-primary' : 'text-base-content'}`}>
        <Calendar size="24"/>
        <span class="dock-label">{t('nav.timetable')}</span>
    </a>
</footer>

<footer class="md:hidden fixed bottom-6 right-6 z-50">
    {isActive('/timetable') ? (
            <a href={l('/explore')} class="btn btn-xl btn-circle btn-accent shadow-xl border-2 ">
                <Telescope size="32" class="text-accent-content"/>
            </a>
    ) : (
            <a href={l('/timetable')} class="btn btn-xl btn-circle btn-accent shadow-xl border-2 ">
                <Calendar size="32" class="text-accent-content"/>
            </a>
    )}
</footer>