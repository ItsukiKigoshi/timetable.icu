---
import LoginButton from "./LoginButton";
import PasskeyButton from "./PasskeyButton.tsx";


const user = Astro.locals.user;
const isLoggedIn = !!user;
---
<header class="navbar sticky  top-0 z-100 bg-base-100 shadow-sm">
    <div class="flex-1">
        <a class="btn btn-ghost text-xl" href="/">ICUのじかんわり</a>
    </div>
    <nav class="flex-none">
    </nav>
    <button class="btn" onclick="login_modal.showModal()">Login</button>
    <dialog id="login_modal" class="modal">
        <div class="modal-box">
            <h3 class="text-lg font-bold">Hello!</h3>
            <p class="py-4">Press ESC key or click the button below to close</p>
            <LoginButton client:load isLoggedIn={isLoggedIn}/>
            <PasskeyButton client:load isLoggedIn={isLoggedIn}/>
            <div class="modal-action">
                <form method="dialog">
                    <!-- if there is a button in form, it will close the modal -->
                    <button class="btn">Close</button>
                </form>
            </div>
        </div>
        <form method="dialog" class="modal-backdrop">
            <button>Close by Click outside the Modal</button>
        </form>
    </dialog>
</header>