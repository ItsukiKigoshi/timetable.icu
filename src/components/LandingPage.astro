---
import {Image} from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import Logo from "@/assets/Logo.svg";
import ProfileImg from "@/assets/profile.webp";
import Cover1 from "@/assets/cover1.webp";
import Cover2 from "@/assets/cover2.webp";
import {
    Bug,
    CalendarCheck2,
    CalendarPlus,
    Search,
    Telescope,
    RefreshCcw,
    ThumbsUp,
    Calendar,
    CalendarArrowUp
} from "lucide-astro";
import {WifiOff} from "lucide-react";

// Landing Page is Rendered as SSG
export const prerender = true;

import {useTranslations, useTranslatedPath} from "@/translation/utils";
import {defaultLang} from "@/translation/ui.ts";
const lang = Astro.locals.lang || defaultLang;
const t = useTranslations(lang);
const l = useTranslatedPath(lang);
---

<Layout title="ICUのじかんわり | 時間割・履修登録ツールの決定版" isLanding={true}>
    <!--背景画像-->
    <aside aria-hidden="true" class="fixed inset-0 -z-10 overflow-hidden pointer-events-none select-none ">
        <Image
                src={Cover1}
                alt=""
                width={800}
                sizes="(max-width: 768px) 400px, 800px"
                quality={50}
                format="webp"
                loading="eager"
                class="absolute -top-10 -right-10 w-185 md:w-200 rotate-12"
        />
        <Image
                src={Cover2}
                alt=""
                height={800}
                sizes="(max-width: 768px) 400px, 800px"
                quality={50}
                format="webp"
                loading="eager"
                class="absolute -bottom-40 -left-20 w-150 md:w-225 -rotate-12"
        />
    </aside>

    <!--Main Content-->
    <section class="flex flex-col items-center gap-16 p-6 max-w-5xl mx-auto mb-20 min-h-screen relative">
        <!--Hero-->
        <section
                class="hero bg-base-200/70 backdrop-blur-xl rounded-[3.5rem] p-10 md:p-20 shadow-2xl w-full max-w-7xl mx-auto mt-12 border border-white/20"
        >
            <header class="hero-content lg:flex-row flex-col gap-12 lg:gap-16">
                <Logo
                        width={200}
                        height={200}
                        class="drop-shadow-2xl"
                />
                <div class="lg:text-left text-center">
                    <h1 class="md:text-5xl text-3xl font-extrabold tracking-tighter leading-tight text-base-content">
                        {t('title')}
                        <span
                                class="block text-2xl lg:inline lg:ml-1 opacity-80"
                        >{t('lp.hero.subtitle')}</span
                        >
                    </h1>
                    <p class="py-4 md:text-lg text-sm font-medium opacity-70 leading-relaxed max-w-3xl">
                        {t('lp.hero.description')}
                    </p>
                    <nav class="flex lg:flex-nowrap flex-wrap lg:justify-start justify-center gap-4">
                        <a
                                href={l('/explore')}
                                class="btn btn-primary btn-lg rounded-full px-16"
                        >
                            <Telescope size="24"/>
                            <span>{t('lp.nav.explore')}</span>
                        </a>

                        <a
                                href={l('/timetable')}
                                class="btn btn-neutral btn-lg rounded-full px-16"
                        >
                            <Calendar size="24"/>
                            <span>{t('lp.nav.timetable')}</span>
                        </a>
                    </nav>
                </div>
            </header>
        </section>

        <section class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full">
            <section class="flex flex-col gap-4">
                <h2 class="flex items-center gap-3 text-2xl font-black px-2">
                    <ThumbsUp size="32"/>
                    {t('lp.features.can.label')}
                </h2>
                <section class="bg-base-100 border border-base-200 rounded-4xl overflow-hidden shadow-sm grow">
                    <ul class="divide-y divide-base-200">
                        <li class="p-6 flex gap-5">
                            <div class="text-primary bg-primary/10 p-3 rounded-2xl h-fit">
                                <Search size="24"/>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">{t('lp.features.can.search.title')}</h3>
                                <p class="text-sm opacity-70 leading-relaxed">
                                    {t('lp.features.can.search.desc')}
                                </p>
                            </div>
                        </li>
                        <li class="p-6 flex gap-5">
                            <div class="text-primary bg-primary/10 p-3 rounded-2xl h-fit">
                                <CalendarCheck2 size="24"/>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">
                                    {t('lp.features.can.schedule.title')}
                                </h3>
                                <p class="text-sm opacity-70 leading-relaxed">
                                    {t('lp.features.can.schedule.desc')}
                                </p>
                            </div>
                        </li>
                        <li class="p-6 flex gap-5">
                            <div class="text-primary bg-primary/10 p-3 rounded-2xl h-fit">
                                <RefreshCcw size="24"/>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">
                                    {t('lp.features.can.sync.title')}
                                </h3>
                                <p class="text-sm opacity-70 leading-relaxed">
                                    {t('lp.features.can.sync.desc')}
                                </p>
                            </div>
                        </li>
                    </ul>
                </section>
            </section>

            <section class="flex flex-col gap-4">
                <h2 class="flex items-center gap-3 text-2xl font-black text-base-content/40 px-2">
                    <Bug size="32"/>
                    {t('lp.features.todo.label')}
                </h2>
                <section class="bg-base-100 border border-base-200 rounded-4xl overflow-hidden grow">
                    <ul class="divide-y divide-base-200">
                        <li class="p-6 flex gap-5">
                            <div class="bg-base-content/10 p-3 rounded-2xl h-fit opacity-50">
                                <WifiOff size="24"/>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">
                                    {t('lp.features.todo.offline.title')}
                                </h3>
                                <p class="text-sm opacity-70 leading-relaxed">
                                    {t('lp.features.todo.offline.desc')}
                                </p>
                            </div>
                        </li>
                        <li class="p-6 flex gap-5">
                            <div class="bg-base-content/10 p-3 rounded-2xl h-fit opacity-50">
                                <CalendarPlus size="24"/>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">
                                    {t('lp.features.todo.custom.title')}
                                </h3>
                                <p class="text-sm opacity-70 leading-relaxed">
                                    {t('lp.features.todo.custom.desc')}
                                </p>
                            </div>
                        </li>
                        <li class="p-6 flex gap-5">
                            <div class="bg-base-content/10 p-3 rounded-2xl h-fit opacity-50">
                                <CalendarArrowUp size="24"/>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">
                                    {t('lp.features.todo.calendar.title')}
                                </h3>
                                <p class="text-sm opacity-70 leading-relaxed">
                                    {t('lp.features.todo.calendar.desc')}
                                </p>
                            </div>
                        </li>
                    </ul>
                </section>
            </section>
        </section>

        <section
                class="bg-base-200/80 rounded-[2.5rem] p-8 md:p-10 w-full shadow-sm border border-base-200 flex flex-col md:flex-row items-center gap-10"
        >
            <Image
                    src={ProfileImg}
                    alt="Itsuki Kigoshi"
                    width={256}
                    height={256}
                    format="webp"
                    quality={80}
                    class="w-32 h-32 rounded-3xl ring overflow-hidden shadow-2xl"
            />
            <address class="text-center md:text-left flex-1 not-italic">
                <h2 class="text-2xl font-black mb-4 items-center gap-2">
                    <span>{t('lp.profile.made_with')}</span>
                    <a
                            href="https://itsukikigoshi.github.io/"
                            target="_blank"
                            class="underline"
                    >
                        Itsuki Kigoshi
                    </a>
                </h2>
                <p class="text-sm md:text-base leading-relaxed opacity-80 mb-6">
                    {t('lp.profile.description.top')} <br/>
                    {t('lp.profile.description.middle')}<br/>
                    {t('lp.profile.description.bottom')}
                    <a
                            class="inline-flex items-center gap-1 underline transition-colors"
                            href="mailto:itsukikigoshi+timetableicu@gmail.com"
                    >
                        {t('lp.profile.contact')}
                    </a>
                    {t('lp.profile.dot')}
                </p>
            </address>
        </section>

        <footer class="flex justify-center gap-8 text-sm opacity-60">
            <a href={l('/privacy')} class="underline">{t('footer.privacy')}</a>
            <a href={l('/terms')} class="underline">{t('footer.terms')}</a>
        </footer>
    </section>
</Layout>
