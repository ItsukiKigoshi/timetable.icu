---
import LoginButton from "../ui/LoginButton.tsx";
import PasskeyButton from "../ui/PasskeyButton.tsx";
import {SELECTABLE_YEARS, SELECTABLE_TERMS} from "@/constants/time.ts";
import Logo from '@/assets/Logo.svg';
import {createTranslationHelper} from "@/lib/translation/utils.ts";
import {defaultLang} from "@/lib/translation/ui.ts";

const lang = Astro.locals.lang || defaultLang;
const {t, l} = createTranslationHelper(lang);

const {user, selectedYear, selectedTerm, dbError} = Astro.locals;
const isLoggedIn = !!user;
---

<header class="navbar sticky top-0 z-80 bg-base-100 shadow-sm">
    <div class="navbar-start">
        <a class="btn btn-ghost text-xl flex gap-2 px-2" href={l('/')}>
            <Logo width={24} height={24}/>
            <span class="hidden sm:inline">{t('site.title')}</span>
        </a>
    </div>

        <div class="navbar-center flex gap-2">
            <label class="flex gap-1 items-center">
                <select
                        id="year-select"
                        class="select select-bordered select-sm md:select-md w-fit font-bold"
                        autocomplete="off"
                >
                    {SELECTABLE_YEARS.map(y => (
                            <option value={y} selected={Number(selectedYear) === y}>
                                {y}
                            </option>
                    ))}
                </select>
                <select
                        id="term-select"
                        class="select select-bordered select-sm md:select-md w-fit font-bold"
                        autocomplete="off"
                >
                    {SELECTABLE_TERMS.map(termObj => (
                            <option value={termObj} selected={selectedTerm === termObj}>
                                {t(`term.${termObj}` as any) || termObj}
                            </option>
                    ))}
                </select>
            </label>
        </div>
    <nav class="navbar-end">
        {!dbError && (
                <div class="relative inline-block ml-auto">
                    <input type="checkbox" id="user-menu-toggle" class="peer hidden"/>
                    <label for="user-menu-toggle"
                           class="fixed inset-0 h-screen w-screen cursor-default hidden peer-checked:block z-90"></label>

                    <label for="user-menu-toggle"
                           class="relative z-101 btn btn-ghost btn-circle avatar hover:bg-base-200 cursor-pointer">
                        <div class="w-10 rounded-full shadow-inner ring-1 ring-base-content/10">
                            {user?.image ? (
                                    <img src={user.image} alt="User Avatar"/>
                            ) : (
                                    <div class="flex h-full w-full items-center justify-center bg-base-200 text-base-content/50">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                                             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                             stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="12" cy="8" r="5"/>
                                            <path d="M20 21a8 8 0 0 0-16 0"/>
                                        </svg>
                                    </div>
                            )}
                        </div>
                    </label>

                    <ul class="hidden peer-checked:flex absolute right-0 z-101 mt-3 w-64 p-4 shadow-xl bg-base-100 rounded-xl border border-base-200 flex-col items-center">
                        <li class="w-full text-center space-y-1">
                            <h3 class="font-bold text-lg">
                                {user ? t('header.hi').replace('{name}', user.name ?? '') : t('header.welcome_back')}
                            </h3>
                            <p class="text-xs text-base-content/60">
                                {isLoggedIn ? t('header.synced') : t('header.login_to_sync')}
                            </p>
                            <div class="w-full join mt-2 border border-base-300">
                                <button
                                        class={`join-item btn btn-sm flex-1 ${lang === 'en' ? 'btn-active btn-neutral' : 'btn-ghost'}`}
                                        data-lang-switch="en"
                                >
                                    EN
                                </button>
                                <button
                                        class={`join-item btn btn-sm flex-1 ${lang === 'ja' ? 'btn-active btn-neutral' : 'btn-ghost'}`}
                                        data-lang-switch="ja"
                                >
                                    JA
                                </button>
                            </div>
                        </li>
                        <div class="divider my-3 opacity-20 w-full"></div>
                        <li class="w-full flex flex-col gap-2">
                            <LoginButton client:load isLoggedIn={isLoggedIn} lang={lang}/>
                            <PasskeyButton client:load isLoggedIn={isLoggedIn} lang={lang}/>
                        </li>
                    </ul>
                </div>
        )}
    </nav>
</header>

<script>
    /**
     * 現在のURLのクエリパラメータを維持したまま
     * Year と Term だけを書き換えて遷移する
     */
    const updateYearTerm = () => {
        const yearSelect = document.getElementById('year-select') as unknown as HTMLSelectElement;
        const termSelect = document.getElementById('term-select') as unknown as HTMLSelectElement;

        if (!yearSelect || !termSelect) return;

        const url = new URL(window.location.href);
        url.searchParams.set('year', yearSelect.value);
        url.searchParams.set('term', termSelect.value);

        // ページネーションがある場合、年度が変わったら1ページ目に戻すのが一般的
        if (url.searchParams.has('page')) {
            url.searchParams.set('page', '1');
        }

        window.location.assign(url.toString());
    };

    // イベントリスナーの登録
    document.getElementById('year-select')?.addEventListener('change', updateYearTerm);
    document.getElementById('term-select')?.addEventListener('change', updateYearTerm);


    // --- 言語切り替えロジック ---
    document.querySelectorAll('[data-lang-switch]').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const targetLang = (e.currentTarget as HTMLButtonElement).dataset.langSwitch;
            const currentUrl = new URL(window.location.href);
            let segments = currentUrl.pathname.split('/').filter(Boolean); // 空の要素を除去

            // 現在英語 (/en) かどうかを判定
            const isCurrentlyEn = segments[0] === 'en';

            if (targetLang === 'en' && !isCurrentlyEn) {
                // 英語へ切り替え: パスの先頭に /en を追加
                segments.unshift('en');
            } else if (targetLang === 'ja' && isCurrentlyEn) {
                // 日本語へ切り替え: パスの先頭から en を削除
                segments.shift();
            } else {
                return; // 変更の必要がない場合は終了
            }

            // パスを再構築 (先頭にスラッシュを忘れずに)
            currentUrl.pathname = '/' + segments.join('/');
            window.location.assign(currentUrl.toString());
        });
    });
</script>