---
import Layout from "./Layout.astro";
import Logo from "@/assets/Logo.svg";
import { createTranslationHelper } from "@/lib/translation/utils.ts";

const locals = Astro.locals ?? {};
const { frontmatter } = Astro.props;

const title = frontmatter?.title;
const description = frontmatter?.description;

const { t, l } = createTranslationHelper(locals.lang);

export const prerender = true;
---
<Layout title={`${title} | ${t('site.title')}`} description={description} showHeader={false} showDBError={false}>
    <header class="navbar min-h-0 h-12 lg:h-16 sticky top-0 z-50 bg-base-100 shadow-sm">
        <nav class="navbar-start">
            <a class="btn btn-ghost text-xl flex gap-2 px-2" href={l('/')}>
                <Logo width={24} height={24}/>
                <h1 class="hidden sm:inline">{t('site.title')}</h1>
            </a>
        </nav>
    </header>
  <section class="container mx-auto px-6 py-12 mb-10">
    <article class="prose max-w-none">
      {frontmatter?.title && <h1 class="mb-8">{frontmatter.title}</h1>}
      <slot />
    </article>
  </section>
</Layout>