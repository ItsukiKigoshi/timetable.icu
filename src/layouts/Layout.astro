---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const locals = Astro.locals ?? {};
const user = locals.user ?? null;
const dbError = locals.dbError;

const {
    title = "ICUのじかんわり | 時間割・履修登録ツールの決定版",
    description = 'ICUのじかんわりで，複雑な時間割・履修登録もお手の物! 公式データから作成した授業一覧・検索機能に，Long 4対応の時間割．これであなたもICUアカデミックプランニングマスター！',
    ogImage = "https://timetable-icu.itsukikigoshi.workers.dev/web-app-manifest-512x512.png",
    ogType = 'website',
    showHeader = true
} = Astro.props;
---
<!doctype html>
<html lang="ja">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <link rel="icon" type="image/png" href="//favicon-96x96.png" sizes="96x96"/>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
    <link rel="shortcut icon" href="/favicon.ico"/>
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png"/>
    <link rel="manifest" href="/site.webmanifest"/>
    <meta name="generator" content={Astro.generator}/>
    <title>{title}</title>
    <!--OG description (dynamic change might be needed)-->
    <meta property="og:title" content={title}/>
    <meta property="og:description" content={description}/>
    <meta property="og:url" content={/*pageUrl ||*/ "https://timetable-icu.itsukikigoshi.workers.dev"}/>
    <meta property="og:site_name" content={/*siteName || */"ICUのじかんわり | 時間割・履修登録ツールの決定版"}/>
</head>
<body class="min-h-screen flex flex-col">
<div role="alert" class="alert alert-error">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
    </svg>
    <span>本サイトは試験運用中です．本番運用開始までの間，データ等は予告無く削除される可能性があります．</span>
</div>
{dbError && (
        <div class="p-4 container mx-auto">
            <div role="alert" class="alert alert-warning shadow-lg">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none"
                     viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
                <div>
                    <h3 class="font-bold">アクセス制限中</h3>
                    <div class="text-xs">
                        現在データベースの読み取り制限に達しているため，検索及び同期などログインが必要な機能が利用できません．1日以内に復旧見込みです．
                        あなたのデータは保存されているのでご安心ください．
                    </div>
                </div>
            </div>
        </div>
)}
{showHeader &&
        <Header user={user}/>}
<main class="grow">
    <slot/>
</main>
<Footer/>
</body>
</html>