---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const {user} = Astro.locals ?? {};
const {
  title = "ICUのじかんわり | 時間割・履修登録ツールの決定版",
  description = 'ICUのじかんわりで，複雑な時間割・履修登録もお手の物! 公式データから作成した授業一覧・検索機能に，Long 4対応の時間割．これであなたもICUアカデミックプランニングマスター！',
  ogImage = "https://timetable-icu.itsukikigoshi.workers.dev/web-app-manifest-512x512.png",
  ogType = 'website',
  showHeader = true} = Astro.props;
---
<!doctype html>
<html lang="ja">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <link rel="icon" type="image/png" href="//favicon-96x96.png" sizes="96x96"/>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
    <link rel="shortcut icon" href="/favicon.ico"/>
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png"/>
    <link rel="manifest" href="/site.webmanifest"/>
    <meta name="generator" content={Astro.generator}/>
    <title>{title}</title>
    <!--OG description (dynamic change might be needed)-->
    <meta property="og:title" content={title} />
      <meta property="og:description" content={description} />
      <meta property="og:url" content={pageUrl || "https://timetable-icu.itsukikigoshi.workers.dev"} />
      <meta property="og:site_name" content={siteName || "ICUのじかんわり | 時間割・履修登録ツールの決定版"}/>
</head>
<body class="min-h-screen flex flex-col">
{showHeader &&
        <Header user={user}/>}
<main class="grow">
    <slot/>
</main>
<Footer/>
</body>
</html>