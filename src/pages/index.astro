---
// Landing Page is Rendered as SSG
export const prerender = true;


import {Image} from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import Logo from "@/assets/Logo.svg";
import ProfileImg from "@/assets/profile.webp";
import Cover1 from "@/assets/cover1.webp";
import Cover2 from "@/assets/cover2.webp";
---

<Layout title="ICUのじかんわり | 時間割・履修登録ツールの決定版" isLanding={true}>
    <!--背景画像-->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none select-none ">
        <Image
                src={Cover1}
                alt="A flower in ICU"
                width={800}
                sizes="(max-width: 768px) 400px, 800px"
                quality={50}
                format="webp"
                class="absolute -top-10 -right-10 w-185 md:w-200 rotate-12"
        />
        <Image
                src={Cover2}
                alt="ICU Cheppel"
                height={800}
                sizes="(max-width: 768px) 400px, 800px"
                quality={50}
                format="webp"
                class="absolute -bottom-40 -left-20 w-150 md:w-225 -rotate-12"
        />
    </div>

    <!--Main Content-->
    <div class="flex flex-col items-center gap-16 p-6 max-w-5xl mx-auto mb-20 min-h-screen relative">
        <!--Hero-->
        <div
                class="hero bg-base-200/70 backdrop-blur-xl rounded-[3.5rem] p-10 md:p-20 shadow-2xl w-full max-w-7xl mx-auto mt-12 border border-white/20"
        >
            <header class="hero-content flex-col lg:flex-row gap-12 lg:gap-20">
                <Logo
                        width={200}
                        height={200}
                        class="drop-shadow-2xl"
                />
                <div class="text-center lg:text-left">
                    <h1 class="text-2xl md:text-4xl font-extrabold tracking-tighter leading-tight text-base-content">
                        ICUのじかんわり
                        <span
                                class="block text-md md:text-2xl lg:inline lg:ml-4  opacity-80"
                        >へようこそ！</span
                        >
                    </h1>
                    <p class="py-4 text-sm md:text-lg font-medium opacity-70 leading-relaxed max-w-3xl">
                        ICU生の時間割、履修登録ツールの決定版
                    </p>
                    <div class="flex flex-wrap justify-center lg:justify-start gap-4">
                        <a
                                href="/explore"
                                class="btn btn-primary btn-md rounded-full px-12 shadow-lg group"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                                 class="group-hover:rotate-12 transition-transform">
                                <path d="m10.065 12.493-6.18 1.318a.934.934 0 0 1-1.108-.702l-.537-2.15a1.07 1.07 0 0 1 .691-1.265l13.504-4.44"/>
                                <path d="m13.56 11.747 4.332-.924"/>
                                <path d="m16 21-3.105-6.21"/>
                                <path d="M16.485 5.94a2 2 0 0 1 1.455-2.425l1.09-.272a1 1 0 0 1 1.212.727l1.515 6.06a1 1 0 0 1-.727 1.213l-1.09.272a2 2 0 0 1-2.425-1.455z"/>
                                <path d="m6.158 8.633 1.114 4.456"/>
                                <path d="m8 21 3.105-6.21"/>
                                <circle cx="12" cy="13" r="2"/>
                            </svg>
                            <span>コースを探す</span>
                        </a>
                        <a
                                href="/timetable"
                                class="btn btn-outline btn-md rounded-full px-12 backdrop-blur-md hover:bg-primary/10 transition-all"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                                 stroke-linejoin="round">
                                <path d="M8 2v4"/>
                                <path d="M16 2v4"/>
                                <rect width="18" height="18" x="3" y="4" rx="2"/>
                                <path d="M3 10h18"/>
                                <path d="M8 14h.01"/>
                                <path d="M12 14h.01"/>
                                <path d="M16 14h.01"/>
                                <path d="M8 18h.01"/>
                                <path d="M12 18h.01"/>
                                <path d="M16 18h.01"/>
                            </svg>
                            <span>時間割を見る</span>
                        </a>
                    </div>
                </div>
            </header>
        </div>

        <!--できること & できないこと-->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full">
            <section class="flex flex-col gap-4">
                <h2
                        class="flex items-center gap-3 text-2xl font-black px-2"
                >
                    <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="28"
                            height="28"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="lucide-laugh"
                    >
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M18 13a6 6 0 0 1-6 5 6 6 0 0 1-6-5h12Z"></path>
                        <line x1="9" x2="9.01" y1="9" y2="9"></line>
                        <line x1="15" x2="15.01" y1="9" y2="9"></line>
                    </svg>
                    できること
                </h2>
                <div
                        class="bg-base-100 border border-base-200 rounded-4xl overflow-hidden shadow-sm grow"
                >
                    <div class="divide-y divide-base-200">
                        <div
                                class="p-6 flex gap-5"
                        >
                            <div
                                    class="text-primary bg-primary/10 p-3 rounded-2xl h-fit"
                            >
                                <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                >
                                    <path d="m17 18-1.535 1.605a5 5 0 0 1-8-1.5"
                                    ></path>
                                    <path d="M17 22v-4h-4"></path>
                                    <path
                                            d="M20.996 15.251A4.5 4.5 0 0 0 17.495 8h-1.79a7 7 0 1 0-12.709 5.607"
                                    ></path>
                                    <path d="M7 10v4h4"></path>
                                    <path d="m7 14 1.535-1.605a5 5 0 0 1 8 1.5"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">
                                    マルチデバイス同期
                                </h3>
                                <p class="text-sm opacity-70 leading-relaxed">
                                    ログインしてすべてのデバイスで最新の時間割を共有
                                </p>
                            </div>
                        </div>
                        <div
                                class="p-6 flex gap-5 hover:bg-base-200/30 transition-colors"
                        >
                            <div
                                    class="text-primary bg-primary/10 p-3 rounded-2xl h-fit"
                            >
                                <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                >
                                    <circle cx="11" cy="11" r="8"></circle>
                                    <path d="m21 21-4.3-4.3"></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">すべてのコースから探す</h3>
                                <p class="text-sm opacity-70 leading-relaxed">
                                    提供されているすべてのコースを簡単に検索・閲覧
                                </p>
                            </div>
                        </div>
                        <div
                                class="p-6 flex gap-5 hover:bg-base-200/30 transition-colors"
                        >
                            <div
                                    class="text-primary bg-primary/10 p-3 rounded-2xl h-fit"
                            >
                                <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                >
                                    <path d="M8 2v4"></path>
                                    <path d="M16 2v4"></path>
                                    <path
                                            d="M21 14V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h8"
                                    ></path>
                                    <path d="M3 10h18"></path>
                                    <path d="m16 20 2 2 4-4"></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">
                                    ICU独自スケジュール対応
                                </h3>
                                <p class="text-sm opacity-70 leading-relaxed">
                                    Long 4, 5, 6,
                                    7など、ICUならではのコマ割りも表示
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="flex flex-col gap-4">
                <h2
                        class="flex items-center gap-3 text-2xl font-black text-base-content/40 px-2"
                >
                    <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="28"
                            height="28"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="lucide-bug"
                    >
                        <path d="M12 20v-9"></path>
                        <path
                                d="M14 7a4 4 0 0 1 4 4v3a6 6 0 0 1-12 0v-3a4 4 0 0 1 4-4z"
                        ></path>
                        <path d="M14.12 3.88 16 2"></path>
                        <path d="M21 21a4 4 0 0 0-3.81-4"></path>
                        <path d="M21 5a4 4 0 0 1-3.55 3.97"></path>
                        <path d="M22 13h-4"></path>
                        <path d="M3 21a4 4 0 0 1 3.81-4"></path>
                        <path d="M3 5a4 4 0 0 0 3.55 3.97"></path>
                        <path d="M6 13H2"></path>
                        <path d="m8 2 1.88 1.88"></path>
                        <path d="M9 7.13V6a3 3 0 1 1 6 0v1.13"></path>
                    </svg>
                    できないこと・検討中
                </h2>
                <div
                        class="bg-base-100 border border-base-200 rounded-4xl overflow-hidden grow"
                >
                    <div
                            class="divide-y divide-base-100 text-base-content/70"
                    >
                        <div
                                class="p-6 flex gap-5 hover:bg-base-200/30 transition-colors"
                        >
                            <div
                                    class="bg-base-content/10 p-3 rounded-2xl h-fit opacity-50"
                            >
                                <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="lucide lucide-book-open-check-icon lucide-book-open-check"
                                >
                                    <path d="M12 21V7"></path>
                                    <path d="m16 12 2 2 4-4"></path>
                                    <path
                                            d="M22 6V4a1 1 0 0 0-1-1h-5a4 4 0 0 0-4 4 4 4 0 0 0-4-4H3a1 1 0 0 0-1 1v13a1 1 0 0 0 1 1h6a3 3 0 0 1 3 3 3 3 0 0 1 3-3h6a1 1 0 0 0 1-1v-1.3"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">
                                    Internationalisation
                                </h3>
                                <p class="text-sm opacity-70 leading-relaxed">
                                    English Compatibility is Planned
                                </p>
                            </div>
                        </div>
                        <div
                                class="p-6 flex gap-5 hover:bg-base-200/30 transition-colors"
                        >
                            <div
                                    class="bg-base-content/10 p-3 rounded-2xl h-fit opacity-50"
                            >
                                <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                >
                                    <path
                                            d="M17.477 12.89A4 4 0 1 1 20 10.3a8 8 0 1 0-6.9 10.1"
                                    ></path>
                                    <line x1="1" y1="1" x2="23" y2="23"></line>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">
                                    オフライン表示
                                </h3>
                                <p class="text-sm opacity-70 leading-relaxed">
                                    閲覧にはインターネット接続が必要
                                </p>
                            </div>
                        </div>
                        <div
                                class="p-6 flex gap-5 hover:bg-base-200/30 transition-colors"
                        >
                            <div
                                    class="bg-base-content/10 p-3 rounded-2xl h-fit opacity-50"
                            >
                                <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                >
                                    <path
                                            d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"
                                    ></path>
                                    <path
                                            d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">
                                    独自コースの追加
                                </h3>
                                <p class="text-sm opacity-70 leading-relaxed">
                                    現在は公式提供コースのみ．カスタム追加機能も検討中
                                </p>
                            </div>
                        </div>
                        <div
                                class="p-6 flex gap-5 hover:bg-base-200/30 transition-colors"
                        >
                            <div
                                    class="bg-base-content/10 p-3 rounded-2xl h-fit opacity-50"
                            >
                                <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="lucide lucide-notebook-pen-icon lucide-notebook-pen"
                                >
                                    <path
                                            d="M13.4 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7.4"
                                    ></path>
                                    <path d="M2 6h4"></path>
                                    <path d="M2 10h4"></path>
                                    <path d="M2 14h4"></path>
                                    <path d="M2 18h4"></path>
                                    <path
                                            d="M21.378 5.626a1 1 0 1 0-3.004-3.004l-5.01 5.012a2 2 0 0 0-.506.854l-.837 2.87a.5.5 0 0 0 .62.62l2.87-.837a2 2 0 0 0 .854-.506z"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">メモ</h3>
                                <p class="text-sm opacity-70 leading-relaxed">
                                    履修メモが出来るようにしたい...
                                </p>
                            </div>
                        </div>
                        <div
                                class="p-6 flex gap-5 hover:bg-base-200/30 transition-colors"
                        >
                            <div
                                    class="bg-base-content/10 p-3 rounded-2xl h-fit opacity-50"
                            >
                                <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                >
                                    <path d="M11 14h1v4"></path>
                                    <path d="M16 2v4"></path>
                                    <path d="M3 10h18"></path>
                                    <path d="M8 2v4"></path>
                                    <rect
                                            x="3"
                                            y="4"
                                            width="18"
                                            height="18"
                                            rx="2"></rect>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">
                                    カレンダー連携
                                </h3>
                                <p class="text-sm opacity-70 leading-relaxed">
                                    外部カレンダーへの書き出し機能を検討中
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <section
                class="bg-base-200/80 rounded-[2.5rem] p-8 md:p-10 w-full shadow-sm border border-base-200"
        >
            <div class="flex flex-col md:flex-row items-center gap-10">
                <div class="avatar">
                    <div
                            class="w-32 h-32 rounded-3xl ring overflow-hidden shadow-2xl"
                    >
                        <Image src={ProfileImg} alt="Itsuki Kigoshi"/>
                    </div>
                </div>
                <div class="text-center md:text-left flex-1">
                    <h2 class="text-2xl font-black mb-4 items-center gap-2">
                        <span>Made with ♥ by</span>
                        <a
                                href="https://itsukikigoshi.github.io/"
                                target="_blank"
                                class="underline"
                        >
                            Itsuki Kigoshi
                        </a>
                    </h2>
                    <p class="text-sm md:text-base leading-relaxed opacity-80 mb-6">
                        ICU '27が愛を込めてお届け🏔️ <br/>
                        開発協力者を募集中！<br/>
                        デザイン，広報，コーディングなどに興味がある方はぜひ
                        <a
                                class="inline-flex items-center gap-1 underline transition-colors"
                                href="mailto:itsukikigoshi+timetableicu@gmail.com"
                        >
                            ご連絡
                            <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="lucide lucide-mail opacity-70"
                            >
                                <path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path>
                                <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                            </svg>
                        </a>
                        を。
                    </p>
                </div>
            </div>
        </section>
        <div class="flex justify-center gap-8 text-sm opacity-60">
            <a href="/privacy" class="underline">Privacy Policy</a>
            <a href="/terms" class="underline">Terms of Service</a>
        </div>
    </div>
</Layout>
