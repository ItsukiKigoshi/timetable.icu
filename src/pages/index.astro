---
import {Image} from 'astro:assets';
import Layout from "@/layouts/Layout.astro";
import Logo from "@/assets/Logo.svg";
import ProfileImg from "@/assets/profile.jpg";
---

<Layout title="ようこそ! | ICUのじかんわり">
    <div class="flex flex-col items-center gap-16 p-6 max-w-5xl mx-auto min-h-screen">

        <header class="hero bg-linear-to-br from-base-200 to-base-300 rounded-[3rem] p-8 md:p-12 shadow-inner w-full mt-8">
            <div class="hero-content flex-col lg:flex-row gap-10">
                <Logo width={220} height={220}
                      class="drop-shadow-xl hover:scale-105 transition-transform duration-300"/>
                <div class="text-center lg:text-left">
                    <h1 class="text-4xl font-black tracking-tight leading-tight">
                        ICUのじかんわり<span
                            class="block text-2xl lg:inline lg:ml-3 font-bold opacity-70">へようこそ！</span>
                    </h1>
                    <p class="py-6 text-lg font-medium opacity-60">ICU生の時間割, 履修登録の決定版！</p>
                    <a href="/explore"
                       class="btn btn-primary btn-lg rounded-full px-10 shadow-lg hover:shadow-primary/30 transition-all">
                        Explore Courses
                    </a>
                </div>
            </div>
        </header>

        <main class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full">
            <section class="flex flex-col gap-4">
                <h2 class="flex items-center gap-3 text-2xl font-black text-primary px-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                         class="lucide-laugh">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M18 13a6 6 0 0 1-6 5 6 6 0 0 1-6-5h12Z"/>
                        <line x1="9" x2="9.01" y1="9" y2="9"/>
                        <line x1="15" x2="15.01" y1="9" y2="9"/>
                    </svg>
                    できること
                </h2>
                <div class="bg-base-100 border border-base-200 rounded-4xl overflow-hidden shadow-sm grow">
                    <div class="divide-y divide-base-200">
                        <div class="p-6 flex gap-5 hover:bg-base-200/30 transition-colors">
                            <div class="text-primary bg-primary/10 p-3 rounded-2xl h-fit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                     stroke-linejoin="round">
                                    <path d="m17 18-1.535 1.605a5 5 0 0 1-8-1.5"/>
                                    <path d="M17 22v-4h-4"/>
                                    <path d="M20.996 15.251A4.5 4.5 0 0 0 17.495 8h-1.79a7 7 0 1 0-12.709 5.607"/>
                                    <path d="M7 10v4h4"/>
                                    <path d="m7 14 1.535-1.605a5 5 0 0 1 8 1.5"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">マルチデバイス同期</h3>
                                <p class="text-sm opacity-70 leading-relaxed">
                                    ログインしてすべてのデバイスで最新の時間割を共有</p>
                            </div>
                        </div>
                        <div class="p-6 flex gap-5 hover:bg-base-200/30 transition-colors">
                            <div class="text-primary bg-primary/10 p-3 rounded-2xl h-fit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                     stroke-linejoin="round">
                                    <circle cx="11" cy="11" r="8"/>
                                    <path d="m21 21-4.3-4.3"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">全コース探索</h3>
                                <p class="text-sm opacity-70 leading-relaxed">
                                    提供されているすべてのコースを簡単に検索・閲覧</p>
                            </div>
                        </div>
                        <div class="p-6 flex gap-5 hover:bg-base-200/30 transition-colors">
                            <div class="text-primary bg-primary/10 p-3 rounded-2xl h-fit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                     stroke-linejoin="round">
                                    <path d="M8 2v4"/>
                                    <path d="M16 2v4"/>
                                    <path d="M21 14V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h8"/>
                                    <path d="M3 10h18"/>
                                    <path d="m16 20 2 2 4-4"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">ICU独自スケジュール対応</h3>
                                <p class="text-sm opacity-70 leading-relaxed">Long 4, 5, 6,
                                    7など、ICUならではのコマ割りも表示</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="flex flex-col gap-4">
                <h2 class="flex items-center gap-3 text-2xl font-black text-base-content/40 px-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                         class="lucide-bug">
                        <path d="M12 20v-9"/>
                        <path d="M14 7a4 4 0 0 1 4 4v3a6 6 0 0 1-12 0v-3a4 4 0 0 1 4-4z"/>
                        <path d="M14.12 3.88 16 2"/>
                        <path d="M21 21a4 4 0 0 0-3.81-4"/>
                        <path d="M21 5a4 4 0 0 1-3.55 3.97"/>
                        <path d="M22 13h-4"/>
                        <path d="M3 21a4 4 0 0 1 3.81-4"/>
                        <path d="M3 5a4 4 0 0 0 3.55 3.97"/>
                        <path d="M6 13H2"/>
                        <path d="m8 2 1.88 1.88"/>
                        <path d="M9 7.13V6a3 3 0 1 1 6 0v1.13"/>
                    </svg>
                    できないこと・検討中
                </h2>
                <div class="bg-base-200/40 border border-base-200 rounded-4xl overflow-hidden grow">
                    <div class="divide-y divide-base-200/60 text-base-content/70">
                        <div class="p-6 flex gap-5 hover:bg-base-200/30 transition-colors">
                            <div class="bg-base-content/10 p-3 rounded-2xl h-fit opacity-50">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                     stroke-linejoin="round"
                                     class="lucide lucide-book-open-check-icon lucide-book-open-check">
                                    <path d="M12 21V7"/>
                                    <path d="m16 12 2 2 4-4"/>
                                    <path d="M22 6V4a1 1 0 0 0-1-1h-5a4 4 0 0 0-4 4 4 4 0 0 0-4-4H3a1 1 0 0 0-1 1v13a1 1 0 0 0 1 1h6a3 3 0 0 1 3 3 3 3 0 0 1 3-3h6a1 1 0 0 0 1-1v-1.3"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">Internationalisation</h3>
                                <p class="text-sm opacity-70 leading-relaxed">
                                    English Compatibility is Planned
                                </p>
                            </div>
                        </div>
                        <div class="p-6 flex gap-5 hover:bg-base-200/30 transition-colors">
                            <div class="bg-base-content/10 p-3 rounded-2xl h-fit opacity-50">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                     stroke-linejoin="round">
                                    <path d="M17.477 12.89A4 4 0 1 1 20 10.3a8 8 0 1 0-6.9 10.1"/>
                                    <line x1="1" y1="1" x2="23" y2="23"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">オフライン表示</h3>
                                <p class="text-sm opacity-70 leading-relaxed">閲覧にはインターネット接続が必要</p>
                            </div>
                        </div>
                        <div class="p-6 flex gap-5 hover:bg-base-200/30 transition-colors">
                            <div class="bg-base-content/10 p-3 rounded-2xl h-fit opacity-50">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                     stroke-linejoin="round">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">独自コースの追加</h3>
                                <p class="text-sm opacity-70 leading-relaxed">
                                    現在は公式提供コースのみ．カスタム追加機能も検討中</p>
                            </div>
                        </div>
                        <div class="p-6 flex gap-5 hover:bg-base-200/30 transition-colors">
                            <div class="bg-base-content/10 p-3 rounded-2xl h-fit opacity-50">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                     stroke-linejoin="round">
                                    <path d="M11 14h1v4"/>
                                    <path d="M16 2v4"/>
                                    <path d="M3 10h18"/>
                                    <path d="M8 2v4"/>
                                    <rect x="3" y="4" width="18" height="18" rx="2"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg">カレンダー連携</h3>
                                <p class="text-sm opacity-70 leading-relaxed">外部カレンダーへの書き出し機能を検討中</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <footer class="bg-base-200/80 rounded-[2.5rem] p-8 md:p-10 w-full shadow-sm border border-base-200 mb-12">
            <div class="flex flex-col md:flex-row items-center gap-10">
                <div class="avatar">
                    <div class="w-32 h-32 rounded-3xl ring overflow-hidden shadow-2xl">
                        <Image src={ProfileImg} alt="Itsuki Kigoshi"/>
                    </div>
                </div>
                <div class="text-center md:text-left flex-1">
                    <h2 class="text-2xl font-black mb-2 flex items-center gap-2 whitespace-nowrap">
                        <span>Made with Love by</span>
                        <a href="https://itsukikigoshi.github.io/" target="_blank" class="underline">
                            Itsuki Kigoshi
                        </a>
                        <a href="mailto:itsukikigoshi+timetableicu@gmail.com" class="inline-flex">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                 stroke-linejoin="round" class="lucide lucide-mail-icon lucide-mail">
                                <path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"/>
                                <rect x="2" y="4" width="20" height="16" rx="2"/>
                            </svg>
                        </a>
                    </h2>
                    <p class="text-sm md:text-base leading-relaxed opacity-80 mb-6">
                        ICU '27の学生が愛を込めて運営中だよん🏔️
                        <br class="hidden md:block"/>
                        開発へ協力していただける方を募集しています！<br class="hidden md:block"/>
                        デザイン，広報，コーディングなどに興味がある，得意な方はぜひご連絡ください．
                    </p>
                </div>
            </div>
        </footer>

    </div>
</Layout>