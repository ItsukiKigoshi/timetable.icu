---
import Layout from "@/layouts/Layout.astro";
import LoginButton from "@/components/LoginButton";

const { user } = Astro.locals;
---

<Layout title="あいしーゆーのじかんわり">
	<main class="p-4">
		<h1 class="text-2xl font-bold mb-4">Timetable.icu (あいしーゆーのじかんわり)</h1>

		{user ? (
			<div class="space-y-2">
				<p class="text-gray-700">
					ようこそ、<strong>{user.name}</strong>さん！ <br />
					<span class="text-sm text-gray-500">({user.email})</span>
				</p>
				<LoginButton client:load />
			</div>
		) : (
			<div class="space-y-4">
				<p class="text-red-500">ICU Net IDでログインしてください。</p>
				<p>在学生であることを証明するためメールアドレス</p>
				<LoginButton client:load />
			</div>
		)}
	</main>
</Layout>