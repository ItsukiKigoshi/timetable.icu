---
import { drizzle } from 'drizzle-orm/d1';
import { eq, and, exists, like, or } from 'drizzle-orm';
import * as schema from '@/db/schema';
import SearchInterface, { type SearchFilters } from '@/components/SearchInterface';
import Layout from "@/layouts/Layout.astro";
import type { Course, CourseWithSchedules } from "@/db/schema";
import { DEFAULT_TERM, DEFAULT_YEAR } from "@/constants/time";
import {env} from "cloudflare:workers";

// 1. ミドルウェアから認証情報と環境変数を取得
const  user  = Astro.locals.user;
const db = drizzle(env.timetable_icu, { schema });

const url = new URL(Astro.request.url);

// 2. クエリパラメータからフィルタ条件を構築
const filters: SearchFilters = {
    year: url.searchParams.get('year') || DEFAULT_YEAR.toString(),
    term: (url.searchParams.get('term') || DEFAULT_TERM) as Course['term'],
    day: url.searchParams.get('day') || null,
    period: url.searchParams.get('period') || null,
    isLong: url.searchParams.get('isLong'),
    categoryId: url.searchParams.get('category') || null,
    q: url.searchParams.get('q') || '',
    page: Math.max(1, parseInt(url.searchParams.get('page') || '1')),
};

// 3. 検索条件 (WHERE句) の組み立て
let conditions = [];

if (filters.year) {
    conditions.push(eq(schema.courses.year, parseInt(filters.year)));
}

if (filters.term) {
    conditions.push(eq(schema.courses.term, filters.term as Course['term']));
}
// キーワード検索 (日本語名、英語名、教員名)
if (filters.q) {
    const searchVal = `%${filters.q}%`;
    conditions.push(
        or(
            like(schema.courses.titleJa, searchVal),
            like(schema.courses.titleEn, searchVal),
            like(schema.courses.instructor, searchVal)
        )
    );
}

// カテゴリ絞り込み (EXISTS句で関連テーブルをチェック)
if (filters.categoryId) {
    conditions.push(exists(
        db.select()
            .from(schema.courseToCategories)
            .where(and(
                eq(schema.courseToCategories.categoryId, filters.categoryId),
                eq(schema.courseToCategories.courseId, schema.courses.id)
            ))
    ));
}

// 曜日・時限の絞り込み (EXISTS句でScheduleテーブルをチェック)
if (filters.day || filters.period) {
    let schedConditions = [eq(schema.courseSchedules.courseId, schema.courses.id)];

    if (filters.day) {
        schedConditions.push(eq(schema.courseSchedules.dayOfWeek, filters.day as any));
    }
    if (filters.period) {
        schedConditions.push(eq(schema.courseSchedules.period, parseInt(filters.period)));
    }

    conditions.push(exists(
        db.select()
            .from(schema.courseSchedules)
            .where(and(...schedConditions))
    ));
}

// 4. データ取得 (並列実行で高速化)
const [allCategories, results] = await Promise.all([
    // カテゴリ一覧 (プルダウン用)
    db.select().from(schema.categories).all(),

    // コース一覧 (リレーションを含む)
    db.query.courses.findMany({
        where: and(...conditions),
        with: { schedules: true },
        limit: 50, // 1ページあたりの件数
        offset: (filters.page - 1) * 50,
    })
]);

// 5. ログイン済みの場合、ユーザーが既に登録しているコースIDを取得
let userCourseIds: number[] = [];
if (user) {
    const userCoursesData = await db
        .select({ id: schema.userCourses.courseId })
        .from(schema.userCourses)
        .where(eq(schema.userCourses.userId, user.id))
        .all();
    userCourseIds = userCoursesData.map(uc => uc.id);
}

// レスポンスヘッダーの設定
Astro.response.headers.set('Content-Type', 'text/html; charset=utf-8');
---

<Layout title="授業検索 | あいしーゆーのじかんわり">
    <main class="max-w-7xl mx-auto px-4 py-6">
        <h1 class="text-2xl font-bold mb-6">授業検索</h1>

        <SearchInterface
                client:load
                initialResults={results as CourseWithSchedules[]}
                filters={filters}
                isLoggedIn={!!user}
                categories={allCategories}
                initialUserCourseIds={userCourseIds}
                user={user}
        />
    </main>
</Layout>