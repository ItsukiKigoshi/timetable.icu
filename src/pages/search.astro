---
import {drizzle} from 'drizzle-orm/d1';
import {eq, and, exists, like, or} from 'drizzle-orm';
import * as schema from '@/db/schema';
import SearchInterface, {type SearchFilters} from '@/components/SearchInterface';
import {env} from "cloudflare:workers";
import {getAuth} from "@/lib/auth";
import Layout from "@/layouts/Layout.astro";
import type {Course, CourseWithSchedules, Term} from "@/db/schema";

const db = drizzle(env.timetable_icu, {schema});
const auth = getAuth(env);

const url = new URL(Astro.request.url);

const currentYear = new Date().getFullYear();

const filters: SearchFilters = {
    year: url.searchParams.get('year') || currentYear.toString(),
    term: url.searchParams.get('term') || 'Spring',
    day: url.searchParams.get('day'),
    period: url.searchParams.get('period'),
    isLong: url.searchParams.get('isLong'),
    categoryId: url.searchParams.get('category'),
    q: url.searchParams.get('q'),
    page: Math.max(1, parseInt(url.searchParams.get('page') || '1')),
};

// 1. カテゴリ一覧を取得 (プルダウン用)
const allCategories = await db.select().from(schema.categories).all();

// 2. 検索条件の組み立て (coursesテーブル基準)
let conditions = [];

if (filters.year) {
    conditions.push(eq(schema.courses.year, parseInt(filters.year)));
}

if (filters.term) {
    conditions.push(eq(schema.courses.term, filters.term as Course['term']));
}

// キーワード検索
if (filters.q) {
    const searchVal = `%${filters.q}%`;
    conditions.push(
        or(
            like(schema.courses.titleJa, searchVal),
            like(schema.courses.titleEn, searchVal),
            like(schema.courses.instructor, searchVal)
        )
    );
}

// カテゴリ絞り込み
if (filters.categoryId) {
    conditions.push(exists(
        db.select()
            .from(schema.courseToCategories)
            .where(and(
                eq(schema.courseToCategories.categoryId, filters.categoryId),
                eq(schema.courseToCategories.courseId, schema.courses.id)
            ))
    ));
}

// 曜日・時限の絞り込み
if (filters.day || filters.period) {
    let schedConditions = [eq(schema.courseSchedules.courseId, schema.courses.id)];
    if (filters.day) schedConditions.push(eq(schema.courseSchedules.dayOfWeek, filters.day as any));
    if (filters.period) schedConditions.push(eq(schema.courseSchedules.period, parseInt(filters.period)));

    conditions.push(exists(
        db.select().from(schema.courseSchedules).where(and(...schedConditions))
    ));
}

// 3. メインデータの取得
// findManyを使うことで、targetIdsを別途取得する手間とJOINエラーを回避
const results = await db.query.courses.findMany({
    where: conditions.length > 0 ? and(...conditions) : undefined,
    with: {schedules: true},
    limit: 20,
    offset: (filters.page - 1) * 20,
}) as CourseWithSchedules[];

// 4. ユーザー登録情報の取得 (追加機能を維持)
const session = await auth.api.getSession({headers: Astro.request.headers});
const userId = session?.user.id;
let userCourseIds: number[] = [];

if (userId) {
    const userCoursesData = await db.select({id: schema.userCourses.courseId})
        .from(schema.userCourses)
        .where(eq(schema.userCourses.userId, userId))
        .all();
    userCourseIds = userCoursesData.map(uc => uc.id);
}

Astro.response.headers.set('Content-Type', 'text/html; charset=utf-8');
---
<Layout title="あいしーゆーのじかんわり">
    <SearchInterface
            client:load
            initialResults={results}
            filters={filters}
            isLoggedIn={!!userId}
            categories={allCategories}
            initialUserCourseIds={userCourseIds}
    />
</Layout>